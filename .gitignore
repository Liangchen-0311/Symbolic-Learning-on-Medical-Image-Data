# ---- Large regenerable artifacts (NOT committed) ----
# Extracted feature matrices: up to 4.4GB each, fully regenerable by re-running
# step4 from the validated formulas. Far over GitHub's 100MB/file limit.
*.npz

# Intermediate feature banks / numeric dumps (regenerable from configs + formulas).
*.pkl
*.npy

# Raw datasets (public Kaggle/Kaggle-mirror data; see README for source/download).
# NOTE: COVIDx_Experiment/data/ (the 15.9k-image balanced *subset* we actually use)
# IS committed; only the full 63GB COVIDx CT-3A source below is excluded.
Brain Tumor MRI Dataset/
datasets/
COVIDx CT/
COVIDx/
COVIDx_CT_subset/
ThirdData/

# Model checkpoints / weights (regenerable; large binaries).
*.pth
*.pt
best_weights.pth

# RL training checkpoints (intermediate, regenerable) + cloud-uploader cruft.
**/checkpoints/
**/feature_bank_resume/
*.baiduyun.uploading.cfg
*.baiduyun.*

# Torch/HF caches
*.cache/

# Run logs.
logs/
*.log

# ---- OS / editor cruft ----
.DS_Store
._*
**/__pycache__/
*.pyc
